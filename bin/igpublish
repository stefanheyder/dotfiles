#!/bin/zsh


echo "Did you update the local master?"
echo "Do you want to see all changes as files only or as diff? [files]"

read asDiff

if [[ -z "$asDiff" ]]; then
    git diff --name-only HEAD HEAD..origin/master .
else
    git diff HEAD HEAD..origin/master .
fi

vim -O $(find . -maxdepth 1 -regextype sed -regex ".*/\(readme\|README\|Readme\|package.json\).*")

echo "Do you want to publish now? [yes]"

read dopublish;

if [[ -z "$dopublish" ]]; then
    npm publish
    git add $(find . -maxdepth 1 -regextype sed -regex ".*/\(readme\|README\|Readme\|package.json\).*")
    igVersionCommit
fi

